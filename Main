const NewspaperAd = () => {
  const [scale, setScale] = useState(1);
  const containerRef = useRef(null);

  useEffect(() => {
    const handleResize = () => {
      if (containerRef.current) {
        const parentWidth = containerRef.current.parentElement.offsetWidth;
        const parentHeight = containerRef.current.parentElement.offsetHeight;
        // 672 is the original width of NewspaperAd (max-w-2xl)
        // 850 is a safe vertical buffer
        const scaleW = (parentWidth - 40) / 672;
        const scaleH = (parentHeight - 40) / 850;
        setScale(Math.min(scaleW, scaleH, 1));
      }
    };
    handleResize();
    const timeout = setTimeout(handleResize, 100);
    window.addEventListener('resize', handleResize);
    return () => {
      window.removeEventListener('resize', handleResize);
      clearTimeout(timeout);
    };
  }, []);

  return (
    <div ref={containerRef} className="flex items-center justify-center w-full h-full overflow-hidden">
      <div 
        style={{ transform: `scale(${scale})`, transformOrigin: 'center' }}
        className="w-[672px] bg-[#1a1a15] p-8 md:p-12 text-[#f4f1ea] shadow-2xl border-[1px] border-white/10 relative flex flex-col justify-between shrink-0"
      >
        <div className="absolute inset-0 opacity-5 pointer-events-none mix-blend-overlay bg-[url('https://www.transparenttextures.com/patterns/paper-fibers.png')]" />
        
        <div className="border-b-[4px] border-[#f4f1ea] pb-4 text-center">
          <h4 className="text-5xl md:text-6xl font-serif font-black tracking-tighter uppercase italic leading-none">The Gazette</h4>
          <div className="flex justify-between items-center text-[10px] font-bold uppercase tracking-[0.3em] opacity-80 px-2 mt-3">
             <span>VOL. XII • ISSUE 04</span>
             <span>SUNDAY, MARCH 15, 2026</span>
             <span>SPECIAL EDITION</span>
          </div>
        </div>

        <div className="grid grid-cols-12 gap-8 pt-10 flex-grow items-center">
          <div className="col-span-7 space-y-6">
            <h5 className="text-7xl font-black leading-[0.8] tracking-tighter uppercase italic">HEAVY<br/><span className="text-indigo-400">PEACE.</span></h5>
            <p className="text-2xl font-serif italic border-l-[8px] border-indigo-400 pl-6 mt-6 leading-tight font-black">
               "Tranquility is no longer a luxury reserved for the few."
            </p>
            <div className="text-[13px] leading-relaxed font-serif space-y-4 text-slate-300">
               <p>Weighted Hug delivers hospital-grade materials directly to your doorstep. By eliminating the factory's heavy lifting, we eliminate the heavy price tag.</p>
               <p className="font-black italic underline decoration-indigo-400 decoration-[3px] underline-offset-4">Build your sanctuary. Reclaim your rest.</p>
            </div>
          </div>

          <div className="col-span-5 border-l border-white/10 pl-8 flex flex-col justify-center space-y-6">
            <div className="bg-indigo-600/10 border border-indigo-500/30 text-white p-6 shadow-2xl rounded-2xl">
               <Heart size={32} className="mb-4 text-indigo-400 fill-indigo-400 mx-auto" />
               <div className="text-center">
                  <span className="text-[10px] font-black opacity-60 uppercase tracking-widest block mb-1">INTRO PRICE</span>
                  <div className="text-5xl font-black text-indigo-400 tracking-tighter leading-none">$49.99</div>
