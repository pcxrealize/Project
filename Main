import React, { useState, useEffect, useRef } from 'react';
import { 
  Heart, 
  ChevronRight, 
  ChevronLeft, 
  ShieldCheck,
  Truck,
  Layers,
  Users,
  DollarSign,
  Globe,
  Zap,
  Package,
  X,
  Shield,
  Info,
  CheckCircle2,
  Library,
  ExternalLink,
  Search,
  Dna,
  BookOpen,
  FileText
} from 'lucide-react';

const App = () => {
  const [activeSection, setActiveSection] = useState('pitch'); 
  const [currentSlide, setCurrentSlide] = useState(0);
  const [showDonateModal, setShowDonateModal] = useState(false);
  const canvasRef = useRef(null);

  // High-density Snowfall Simulation
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let animationFrameId;

    const handleResize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };

    window.addEventListener('resize', handleResize);
    handleResize();

    const particles = [];
    const count = 400; 
    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        size: Math.random() * 2 + 0.5,
        speedY: Math.random() * 0.5 + 0.2,
        opacity: Math.random() * 0.4 + 0.1,
        wind: Math.random() * 0.1 - 0.05 
      });
    }

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#020617';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      particles.forEach(p => {
        p.y += p.speedY;
        p.x += p.wind;
        
        if (p.y > canvas.height) p.y = -10;
        if (p.x > canvas.width) p.x = 0;
        if (p.x < 0) p.x = canvas.width;
        
        ctx.fillStyle = `rgba(255, 255, 255, ${p.opacity})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      });
      animationFrameId = requestAnimationFrame(animate);
    };
    animate();
    return () => {
      window.removeEventListener('resize', handleResize);
      cancelAnimationFrame(animationFrameId);
    };
  }, []);

  const slides = [
    { id: 1, content: <Slide1 /> },
    { id: 2, content: <Slide2 /> },
    { id: 3, content: <Slide3 /> },
    { id: 4, content: <Slide4 /> },
    { id: 5, content: <Slide5 /> },
    { id: 6, content: <Slide6 /> },
    { id: 7, content: <Slide7 /> },
    { id: 8, content: <Slide8 /> },
    { id: 9, content: <Slide9 /> },
    { id: 10, content: <Slide10 /> },
    { id: 11, content: <Slide11 /> }
  ];

  return (
    <div className="relative h-screen w-full bg-slate-950 text-slate-100 font-sans overflow-hidden flex flex-col select-none">
      <canvas ref={canvasRef} className="fixed top-0 left-0 w-full h-full pointer-events-none z-0" />

      {/* Navigation Header */}
      <nav className="relative z-50 bg-slate-950/80 backdrop-blur-xl border-b border-white/5 px-6 py-4 flex justify-between items-center flex-shrink-0">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(79,70,229,0.5)]">
            <Heart className="text-white fill-white" size={20} />
          </div>
          <div className="hidden sm:flex flex-col">
            <span className="font-black uppercase tracking-tighter text-base leading-none italic">The Weighted Hug</span>
          </div>
        </div>
        
        <div className="flex bg-slate-900/80 rounded-2xl p-1 border border-white/10">
          {[
            { id: 'pitch', label: 'Pitch Deck' },
            { id: 'business_plan', label: 'Business Plan' },
            { id: 'advertisement', label: 'Newspaper Ad' }
          ].map(tab => (
            <button
              key={tab.id}
              onClick={() => { setActiveSection(tab.id); setCurrentSlide(0); }}
              className={`px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${activeSection === tab.id ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/40' : 'text-slate-400 hover:text-white'}`}
            >
              {tab.label}
            </button>
          ))}
        </div>

        <button 
          onClick={() => setShowDonateModal(true)}
          className="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-xl text-xs font-black uppercase tracking-wider transition-all shadow-lg shadow-emerald-900/30"
        >
          Donate Now :)
        </button>
      </nav>

      {/* Main Container */}
      <main className="relative z-10 flex-grow flex flex-col items-center overflow-hidden p-4 md:p-6">
        <div className="w-full max-w-6xl h-full flex flex-col">
          
          {activeSection === 'pitch' && (
            <div className="h-full flex flex-col items-center animate-in fade-in duration-500 overflow-hidden">
              <div className="w-full flex-grow bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-[2rem] md:rounded-[3rem] p-4 md:p-8 flex items-center justify-center relative shadow-2xl overflow-hidden mb-4">
                {/* Progress Indicators */}
                <div className="absolute top-0 left-0 w-full p-6 flex gap-1 md:gap-2 justify-center z-20">
                  {slides.map((_, idx) => (
                    <div 
                      key={idx}
                      className={`h-1 rounded-full transition-all duration-500 ${idx <= currentSlide ? 'bg-indigo-500 w-6 md:w-10' : 'bg-white/10 w-2 md:w-3'}`}
                    />
                  ))}
                </div>
                <div className="w-full h-full flex items-center justify-center overflow-y-auto custom-scrollbar pt-12 pb-6 px-4">
                  <div className="w-full max-w-5xl py-4 flex flex-col items-center">
                    {slides[currentSlide].content}
                  </div>
                </div>
              </div>
              
              {/* Slide Controls */}
              <div className="flex items-center gap-6 md:gap-8 bg-slate-900/90 backdrop-blur-3xl border border-white/10 px-6 py-2 md:py-3 rounded-full shadow-2xl mb-2">
                <button 
                  onClick={() => setCurrentSlide(prev => Math.max(0, prev - 1))} 
                  className="p-2 hover:bg-white/10 rounded-full transition-colors disabled:opacity-10"
                  disabled={currentSlide === 0}
                >
                  <ChevronLeft size={24} />
                </button>
                <div className="flex items-center gap-3 text-sm font-black tracking-widest font-mono">
                  <span className="text-indigo-400">{String(currentSlide + 1).padStart(2, '0')}</span>
                  <span className="opacity-20">/</span>
                  <span className="opacity-50">{String(slides.length).padStart(2, '0')}</span>
                </div>
                <button 
                  onClick={() => setCurrentSlide(prev => Math.min(slides.length - 1, prev + 1))} 
                  className="p-2 hover:bg-white/10 rounded-full transition-colors disabled:opacity-10"
                  disabled={currentSlide === slides.length - 1}
                >
                  <ChevronRight size={24} />
                </button>
              </div>
            </div>
          )}

          {activeSection === 'business_plan' && (
             <div className="h-full overflow-y-auto pr-4 custom-scrollbar animate-in slide-in-from-bottom-6 duration-700">
                <BusinessPlan />
             </div>
          )}
          
          {activeSection === 'advertisement' && (
            <div className="h-full flex items-center justify-center animate-in fade-in duration-1000 overflow-y-auto custom-scrollbar p-2">
               <NewspaperAd />
            </div>
          )}
        </div>
      </main>

      {/* Donation Modal */}
      {showDonateModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-6">
          <div className="absolute inset-0 bg-slate-950/90 backdrop-blur-md" onClick={() => setShowDonateModal(false)} />
          <div className="relative bg-slate-900 border border-white/10 p-10 rounded-[3rem] w-full max-w-md shadow-2xl animate-in zoom-in-95 duration-300">
            <button onClick={() => setShowDonateModal(false)} className="absolute top-8 right-8 text-slate-400 hover:text-white transition-colors">
              <X size={24} />
            </button>
            <div className="text-center mb-10">
              <div className="w-20 h-20 bg-emerald-500/20 rounded-[2rem] flex items-center justify-center mx-auto mb-6 text-emerald-400">
                <DollarSign size={40} />
              </div>
              <h2 className="text-3xl font-black uppercase tracking-tighter italic text-emerald-400">Donate Now :)</h2>
              <p className="text-slate-400 text-xs mt-2 uppercase tracking-widest font-bold">Support the Founders</p>
            </div>
            
            <div className="space-y-4">
              <a href="https://cash.app/$LaRrYKoOPA07" target="_blank" rel="noopener noreferrer" className="group block p-6 bg-white/5 border border-white/10 rounded-3xl hover:bg-indigo-600 transition-all">
                <div className="flex justify-between items-center">
                  <div>
                    <p className="text-[10px] font-black uppercase tracking-widest text-indigo-400 group-hover:text-white mb-1">Founder & CEO</p>
                    <p className="text-xl font-black italic">Bryce</p>
                    <p className="text-xs font-mono opacity-50 mt-1">$LaRrYKoOPA07</p>
                  </div>
                  <ChevronRight size={20} className="group-hover:translate-x-1 transition-transform" />
                </div>
              </a>
              <a href="https://cash.app/$pcxclipz" target="_blank" rel="noopener noreferrer" className="group block p-6 bg-white/5 border border-white/10 rounded-3xl hover:bg-indigo-600 transition-all">
                <div className="flex justify-between items-center">
                  <div>
                    <p className="text-[10px] font-black uppercase tracking-widest text-indigo-400 group-hover:text-white mb-1">Website Developer</p>
                    <p className="text-xl font-black italic">Brandon</p>
                    <p className="text-xs font-mono opacity-50 mt-1">$pcxclipz</p>
                  </div>
                  <ChevronRight size={20} className="group-hover:translate-x-1 transition-transform" />
                </div>
              </a>
            </div>
          </div>
        </div>
      )}

      <style>{`
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
      `}</style>
    </div>
  );
};

// --- SLIDES COMPONENTS ---

